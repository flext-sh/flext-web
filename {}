                    nested_content_type = headers.get(c.Web.Http.HEADER_CONTENT_TYPE)
                    if isinstance(nested_content_type, str):
                        return (
                            c.Web.Http.CONTENT_TYPE_JSON in nested_content_type.lower()
                        )
                return False

